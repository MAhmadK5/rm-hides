generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}
model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  price       String   // e.g., "Rs. 4,500"
  description String
  colors      String[] // e.g., ["Espresso Brown", "Midnight Black"]
  images      String[] // Array of image URLs
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}